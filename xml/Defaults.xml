        <reverse>yes</reverse>
        <pulseonselect>false</pulseonselect>
    </default>



    <default type="progress">
        <texturebg colordiffuse="2f5f5f5f" border="4">diffuse/progress-bg.png</texturebg>
        <lefttexture colordiffuse="$VAR[ColorHighlight]" border="4">diffuse/progress-left.png</lefttexture>
        <midtexture colordiffuse="$VAR[ColorHighlight]" border="4">diffuse/progress-end.png</midtexture>
        <righttexture colordiffuse="$VAR[ColorHighlight]" border="4">diffuse/progress-right.png</righttexture>
