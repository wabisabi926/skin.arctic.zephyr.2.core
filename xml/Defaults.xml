    <default type="spincontrolex">
        <font>font_small</font>
        <spinwidth>32</spinwidth>
        <spinheight>32</spinheight>
        <textcolor>dialog_fg_70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <disabledcolor>dialog_fg_12</disabledcolor>
        <selectedcolor>$VAR[ColorHighlight]</selectedcolor>
        <texturefocus colordiffuse="dialog_bg_12">common/white.png</texturefocus>
        <texturenofocus/>
        <textureup flipy="true" colordiffuse="dialog_fg_30">buttons/spin-down.png</textureup>
        <texturedown colordiffuse="dialog_fg_30">buttons/spin-down.png</texturedown>
        <textureupfocus flipy="true" colordiffuse="Selected">buttons/spin-down.png</textureupfocus>
        <texturedownfocus colordiffuse="Selected">buttons/spin-down.png</texturedownfocus>
        <textureupdisabled flipy="true" colordiffuse="dialog_fg_12">buttons/spin-down.png</textureupdisabled>
        <texturedowndisabled colordiffuse="dialog_fg_12">buttons/spin-down.png</texturedowndisabled>
        <textoffsetx>30</textoffsetx>
        <align>left</align>
        <aligny>center</aligny>
        <reverse>yes</reverse>
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="spincontrol">
        <font>font_small</font>
        <spinwidth>32</spinwidth>
        <spinheight>32</spinheight>
