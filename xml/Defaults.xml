<includes>

    <default type="label">
        <aligny>center</aligny>
        <font>font_small</font>
        <textcolor>dialog_fg_70</textcolor>
        <focusedcolor>dialog_fg_70</focusedcolor>
        <selectedcolor>$VAR[ColorHighlight]</selectedcolor>
        <disabledcolor>dialog_fg_30</disabledcolor>
    </default>

    <default type="edit">
        <align>center</align>
        <aligny>center</aligny>
        <font>font_small</font>
        <textoffsetx>30</textoffsetx>
        <textcolor>dialog_fg_70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <selectedcolor>$VAR[ColorHighlight]</selectedcolor>
        <disabledcolor>dialog_fg_12</disabledcolor>
        <texturefocus colordiffuse="dialog_bg_30">common/white.png</texturefocus>
        <texturenofocus/>
        <pulseonselect>false</pulseonselect>
    </default>

    <default type="fadelabel">
        <align>left</align>
        <aligny>center</aligny>
        <font>font_small</font>
        <textcolor>dialog_fg_70</textcolor>
        <focusedcolor>Selected</focusedcolor>
        <selectedcolor>$VAR[ColorHighlight]</selectedcolor>
        <disabledcolor>dialog_fg_12</disabledcolor>
        <scrollout>false</scrollout>
        <pauseatend>2000</pauseatend>
    </default>

    <default type="image">
    </default>

    <default type="button">
        <align>center</align>
