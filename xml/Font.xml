<?xml version="1.0" encoding="UTF-8"?>

<!-- Artic: Zephyr 2 Core -->


<fonts>

 <fontset id="Default" unicode="true">

        <include condition="Skin.HasSetting(FauneFonts)">Defaults_FauneFonts</include>
        <include condition="!Skin.HasSetting(FauneFonts) + String.StartsWith(System.Language,Chinese) | !Skin.HasSetting(FauneFonts) + String.StartsWith(System.Language,Japanese) | !Skin.HasSetting(FauneFonts) + String.StartsWith(System.Language,Korean)">Defaults_CJKFonts</include>
        <include condition="!Skin.HasSetting(FauneFonts) + !String.StartsWith(System.Language,Chinese) + !String.StartsWith(System.Language,Japanese) + !String.StartsWith(System.Language,Korean)">Defaults_RobotoFonts</include>

        <include condition="String.StartsWith(System.Language,Chinese) | String.StartsWith(System.Language,Japanese) | String.StartsWith(System.Language,Korean)">Defaults_CJKMainFonts</include>
        <include condition="!String.StartsWith(System.Language,Chinese) + !String.StartsWith(System.Language,Japanese) + !String.StartsWith(System.Language,Korean)">Defaults_RobotoMainFonts</include>

        <include>VideoLyrics_Fonts</include>

    </fontset>

    <fontset id="Noto Sans CJK" unicode="true">

        <include condition="Skin.HasSetting(FauneFonts)">Defaults_FauneFonts</include>
        <include condition="!Skin.HasSetting(FauneFonts)">Defaults_CJKFonts</include>

        <include>Defaults_CJKMainFonts</include>

        <include>VideoLyrics_Fonts</include>

    </fontset>

</fonts>


<!-- Artic: Zephyr 2 Core -->